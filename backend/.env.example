# ==================== 应用配置 ====================
APP_NAME=简历筛选平台
DEBUG=true
# 生成命令：python -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=please-change-me-to-a-random-32-byte-secret
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# ==================== 数据库配置 ====================
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=resume

# ==================== Redis 配置 ====================
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_DB=0
# 无密码时留空
REDIS_PASSWORD=

# ==================== LLM 配置 ====================
# 模型名直接传给 OpenAI Chat Completions 协议，不要加 "openai/" 前缀。
# DashScope 兼容模式可选：qwen-plus / qwen-max / qwen-turbo 等
# DeepSeek 官方兼容模式：deepseek-chat / deepseek-reasoner
OPENAI_API_KEY=sk-your-api-key
OPENAI_API_BASE=https://dashscope.aliyuncs.com/compatible-mode/v1
OPENAI_MODEL=qwen-plus
FALLBACK_MODEL=qwen-turbo

# ==================== 存储配置 ====================
# LOCAL：本地文件系统（开发推荐）；后续可扩展 OSS/S3
STORAGE_TYPE=LOCAL
LOCAL_STORAGE_PATH=./note

# ==================== 邮件配置 ====================
# 用于注册校验码、密码重置等通知邮件
SMTP_HOST=smtp.163.com
SMTP_PORT=465
SMTP_USER=your-email@163.com
SMTP_PASSWORD=your-smtp-auth-token
EMAIL_FROM=your-email@163.com

# ==================== Celery 配置 ====================
# 使用与 Redis 同实例的不同 db：1 作 broker，2 存结果
CELERY_BROKER_URL="redis://:${REDIS_PASSWORD}@${REDIS_HOST}:${REDIS_PORT}/1"
CELERY_RESULT_BACKEND="redis://:${REDIS_PASSWORD}@${REDIS_HOST}:${REDIS_PORT}/2"

# ==================== 日志配置 ====================
LOGGING_LEVEL=INFO

# ==================== 初始管理员（首次部署引导） ====================
# 空库 / 没有任何 is_admin=1 的员工时，应用启动会按以下字段创建一个管理员。
# 任意管理员已存在则自动跳过；线上部署务必改成强密码。
INIT_ADMIN_EMAIL=admin@example.com
INIT_ADMIN_PASSWORD=please-change-me
INIT_ADMIN_REAL_NAME=超级管理员
INIT_ADMIN_EMP_NO=ADMIN001
