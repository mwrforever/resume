# =============================================================================
# 生产环境配置模板 —— 复制为 .env.production 后填值
# 凡有 *** CHANGE ME *** 标记的必须修改！
# 生成随机串：python -c "import secrets; print(secrets.token_urlsafe(32))"
# =============================================================================

# ===== 镜像版本（可选） =====
IMAGE_TAG=latest

# ===== 对外暴露的 web 端口 =====
WEB_PORT=80

# ===== 应用核心 =====
APP_NAME=简历筛选平台
DEBUG=false
SECRET_KEY=*** CHANGE ME (32+ random bytes) ***
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7
LOGGING_LEVEL=INFO

# ===== MySQL =====
# DB_ROOT_PASSWORD 给 mysql 容器初始化 root 用，应用走 DB_USER
DB_ROOT_PASSWORD=*** CHANGE ME ***
DB_NAME=resume
DB_USER=resume_app
DB_PASSWORD=*** CHANGE ME ***
DB_PORT=3306
# DB_HOST 在 compose 中被强制改为 mysql，不要在这里改

# ===== Redis =====
# 留空表示不启用密码（仅靠 docker 网络隔离）；生产建议设强密码
REDIS_PASSWORD=
REDIS_PORT=6379
REDIS_DB=0

# ===== LLM =====
OPENAI_API_KEY=*** CHANGE ME (sk-...) ***
OPENAI_API_BASE=https://dashscope.aliyuncs.com/compatible-mode/v1
OPENAI_MODEL=qwen-plus
FALLBACK_MODEL=qwen-turbo

# ===== 存储 =====
STORAGE_TYPE=LOCAL
# LOCAL_STORAGE_PATH 在 compose 中被强制改为 /app/note（挂载到 resume_storage 卷）

# ===== LangGraph Checkpointer =====
# 在 compose 中被强制改为 /app/data/langgraph_checkpoints.sqlite（挂载到 langgraph_data 卷）

# ===== 邮件 SMTP =====
SMTP_HOST=smtp.163.com
SMTP_PORT=465
SMTP_USER=*** CHANGE ME ***
SMTP_PASSWORD=*** CHANGE ME ***
EMAIL_FROM=*** CHANGE ME ***

# ===== Celery（默认空 → 自动用同库 Redis 的 db=1/2） =====
CELERY_BROKER_URL=
CELERY_RESULT_BACKEND=

# ===== 初始管理员（首次启动若没有管理员则创建） =====
# 上线后第一次登录请立即改密码或在管理后台创建正式账号
INIT_ADMIN_EMAIL=admin@example.com
INIT_ADMIN_PASSWORD=*** CHANGE ME ***
INIT_ADMIN_REAL_NAME=超级管理员
INIT_ADMIN_EMP_NO=ADMIN001
